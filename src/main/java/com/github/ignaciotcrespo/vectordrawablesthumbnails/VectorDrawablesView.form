<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.github.ignaciotcrespo.vectordrawablesthumbnails.VectorDrawablesView">
  <grid id="27dc6" binding="panelMain" custom-create="true" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="empty">
      <size top="10" left="10" bottom="10" right="10"/>
    </border>
    <children>
      <scrollpane id="d09d6" binding="vectorsContainer" custom-create="true">
        <constraints border-constraint="Center"/>
        <properties>
          <horizontalScrollBarPolicy value="31"/>
        </properties>
        <border type="none"/>
        <children>
          <grid id="dc56e" binding="panelVectors" custom-create="true" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints/>
            <properties>
              <enabled value="false"/>
              <opaque value="true"/>
            </properties>
            <border type="none"/>
            <children/>
          </grid>
        </children>
      </scrollpane>
      <grid id="3cd78" layout-manager="BorderLayout" hgap="5" vgap="5">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="a241b" binding="panelFilter" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints border-constraint="South"/>
            <properties>
              <enabled value="false"/>
            </properties>
            <border type="none"/>
            <children>
              <grid id="a8b5" layout-manager="BorderLayout" hgap="0" vgap="0">
                <constraints border-constraint="Center"/>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="2105" class="javax.swing.JLabel">
                    <constraints border-constraint="West"/>
                    <properties>
                      <text value="Filter"/>
                    </properties>
                  </component>
                  <component id="d4f90" class="javax.swing.JTextField" binding="textFilter">
                    <constraints border-constraint="Center"/>
                    <properties/>
                  </component>
                  <component id="ae807" class="javax.swing.JButton" binding="clearButton" default-binding="true">
                    <constraints border-constraint="East"/>
                    <properties>
                      <text value="Clear"/>
                    </properties>
                  </component>
                </children>
              </grid>
              <grid id="a9e73" layout-manager="BorderLayout" hgap="0" vgap="0">
                <constraints border-constraint="North"/>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="e05b4" class="javax.swing.JLabel">
                    <constraints border-constraint="West"/>
                    <properties>
                      <text value="Sort By"/>
                    </properties>
                  </component>
                  <component id="a4e35" class="javax.swing.JComboBox" binding="comboSort">
                    <constraints border-constraint="Center"/>
                    <properties>
                      <model>
                        <item value="Unsorted"/>
                        <item value="By Name"/>
                        <item value="By Width"/>
                        <item value="By Height"/>
                        <item value="By Width x Height"/>
                        <item value="By File Size"/>
                      </model>
                    </properties>
                  </component>
                  <component id="29a96" class="javax.swing.JComboBox" binding="comboSortDirection">
                    <constraints border-constraint="East"/>
                    <properties>
                      <model>
                        <item value="Asc"/>
                        <item value="Desc"/>
                      </model>
                    </properties>
                  </component>
                </children>
              </grid>
            </children>
          </grid>
          <component id="69696" class="javax.swing.JButton" binding="btnRefresh">
            <constraints border-constraint="Center"/>
            <properties>
              <text value="Refresh"/>
            </properties>
          </component>
          <component id="8f753" class="javax.swing.JButton" binding="btnDonate">
            <constraints border-constraint="East"/>
            <properties>
              <label value="♡"/>
              <text value="♡"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
  <buttonGroups>
    <group name="buttonGroupSort">
      <member id="3615d"/>
      <member id="1a43"/>
      <member id="93d61"/>
      <member id="dc035"/>
    </group>
  </buttonGroups>
</form>
