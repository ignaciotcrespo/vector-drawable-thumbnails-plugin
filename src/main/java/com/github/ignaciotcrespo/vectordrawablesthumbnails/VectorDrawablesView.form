<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.github.ignaciotcrespo.vectordrawablesthumbnails.VectorDrawablesView">
  <grid id="27dc6" binding="panelMain" custom-create="true" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <scrollpane id="d09d6" binding="vectorsContainer" custom-create="true">
        <constraints border-constraint="Center"/>
        <properties>
          <horizontalScrollBarPolicy value="31"/>
        </properties>
        <border type="none"/>
        <children>
          <grid id="dc56e" binding="panelVectors" custom-create="true" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints/>
            <properties/>
            <border type="none"/>
            <children/>
          </grid>
        </children>
      </scrollpane>
      <grid id="3cd78" layout-manager="BorderLayout" hgap="5" vgap="5">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="a241b" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints border-constraint="South"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="d4f90" class="javax.swing.JTextField" binding="textFilter">
                <constraints border-constraint="Center"/>
                <properties/>
              </component>
              <component id="ae807" class="javax.swing.JButton" binding="clearButton" default-binding="true">
                <constraints border-constraint="East"/>
                <properties>
                  <text value="Clear"/>
                </properties>
              </component>
              <component id="2105" class="javax.swing.JLabel">
                <constraints border-constraint="West"/>
                <properties>
                  <text value="Filter"/>
                </properties>
              </component>
              <grid id="299f1" layout-manager="BorderLayout" hgap="0" vgap="0">
                <constraints border-constraint="North"/>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="e05b4" class="javax.swing.JLabel">
                    <constraints border-constraint="West"/>
                    <properties>
                      <text value="Sort By"/>
                    </properties>
                  </component>
                  <grid id="a9e73" layout-manager="GridBagLayout">
                    <constraints border-constraint="Center"/>
                    <properties/>
                    <border type="none"/>
                    <children>
                      <component id="1a43" class="javax.swing.JRadioButton" binding="radioSortName">
                        <constraints>
                          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                          <gridbag weightx="0.0" weighty="0.0"/>
                        </constraints>
                        <properties>
                          <text value="Name"/>
                        </properties>
                      </component>
                      <component id="3615d" class="javax.swing.JRadioButton" binding="radioSortUnsorted">
                        <constraints>
                          <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                          <gridbag weightx="0.0" weighty="0.0"/>
                        </constraints>
                        <properties>
                          <selected value="true"/>
                          <text value="Unsorted"/>
                        </properties>
                      </component>
                    </children>
                  </grid>
                </children>
              </grid>
            </children>
          </grid>
          <toolbar id="c2569">
            <constraints border-constraint="Center"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="69696" class="javax.swing.JButton" binding="btnRefresh">
                <constraints/>
                <properties>
                  <text value="Refresh"/>
                </properties>
              </component>
            </children>
          </toolbar>
        </children>
      </grid>
    </children>
  </grid>
  <buttonGroups>
    <group name="buttonGroupSort">
      <member id="3615d"/>
      <member id="1a43"/>
    </group>
  </buttonGroups>
</form>
