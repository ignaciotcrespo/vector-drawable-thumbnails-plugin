<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.github.ignaciotcrespo.vectordrawablesthumbnails.VectorDrawablesView">
  <grid id="27dc6" binding="panelMain" custom-create="true" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="307d3" class="javax.swing.JButton" binding="btnRefresh">
        <constraints border-constraint="North"/>
        <properties>
          <text value="Button"/>
        </properties>
      </component>
      <grid id="6e5f9" binding="panelWithToolbar" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <scrollpane id="d09d6" binding="vectorsContainer" custom-create="true">
            <constraints border-constraint="Center"/>
            <properties>
              <horizontalScrollBarPolicy value="31"/>
            </properties>
            <border type="none"/>
            <children>
              <grid id="dc56e" binding="panelVectors" custom-create="true" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="true" same-size-vertically="true" hgap="-1" vgap="-1">
                <margin top="0" left="0" bottom="0" right="0"/>
                <constraints/>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
            </children>
          </scrollpane>
        </children>
      </grid>
    </children>
  </grid>
</form>
